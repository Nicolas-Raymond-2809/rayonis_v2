---
import Layout from '../../layouts/Layout.astro';
import Marquee from '../../components/Marquee.astro';
import SanwaButton from '../../components/SanwaButton.astro';
import ExpertiseCard from '../../components/ExpertiseCard.astro';
import { missions } from '../../data/missions';

export async function getStaticPaths() {
  return missions.map((mission) => ({
    params: { slug: mission.slug },
    props: { mission },
  }));
}

const { mission } = Astro.props;

// Logic for similar missions (same category or just next 3)
const similarMissions = missions
  .filter(m => m.slug !== mission.slug)
  .sort((a, b) => {
    if (a.category === mission.category) return -1;
    if (b.category === mission.category) return 1;
    return 0;
  })
  .slice(0, 3);

const colorScale = {
  main: "main",
  magenta: "magenta",
  alert: "alert"
};

const c = mission.color;
const themeColorClass = `text-${c}`;
const themeBorderClass = `border-${c}`;
const themeBgClass = `bg-${c}`;
const themeGlowClass = `glow-${c === 'main' ? 'cyan' : c === 'alert' ? 'red' : 'magenta'}`;
---

<Layout title={`Mission Briefing | ${mission.title}`}>
  <Marquee />
  
  <main class="pt-8 px-4 md:px-8 pb-32 min-h-screen">
    <!-- Header Section -->
    <header class={`mb-12 border-b-8 ${themeBorderClass} pb-8 animate-slide-in relative`}>
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div class="flex-grow">
          <div class={`inline-block ${themeBgClass} text-black px-4 py-1 font-black uppercase text-[10px] mb-4 border-2 border-black shadow-brutal`}>
            MISSION BRIEFING: STAGE {mission.stage} // {mission.category}
          </div>
          <h1 class="text-5xl md:text-8xl font-black uppercase text-white tracking-tighter leading-none mb-4 drop-shadow-[0_8px_15px_rgba(0,0,0,0.5)]">
            {mission.title}
          </h1>
          <p class={`text-xl md:text-3xl font-bold ${themeColorClass} italic tracking-wide max-w-3xl leading-snug`}>
            &gt; {mission.tagline}
          </p>
        </div>
        
        <div class="hidden md:block text-right">
           <div class="text-[10px] font-black uppercase text-secondary/30 mb-2">Statut Système</div>
           <div class={`text-2xl font-black ${themeColorClass} animate-pulse`}>SÉCURISÉ</div>
        </div>
      </div>
      
      <!-- OS Decorative Grid -->
      <div class="absolute -top-4 -right-4 w-32 h-32 opacity-10 pointer-events-none overflow-hidden hidden lg:block">
          <div class={`grid grid-cols-4 gap-1 w-full h-full`}>
              {[...Array(16)].map(() => <div class={`${themeBgClass} w-2 h-2`}></div>)}
          </div>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
      <!-- Left: Visual & Intent -->
      <div class="lg:col-span-5 flex flex-col gap-10">
        <div class={`relative aspect-video border-8 border-black shadow-brutal-${c} overflow-hidden group`}>
          <img 
            src={mission.imageUrl} 
            alt={mission.title} 
            class="w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 transition-all duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
          <div class="absolute bottom-4 left-4 right-4">
             <div class={`h-1 w-full ${themeBgClass} opacity-30 mb-2`}></div>
             <div class="text-[8px] font-mono text-white/40 uppercase tracking-[0.4em]">Signal Alpha-7 Encryption Enabled</div>
          </div>
        </div>

        <div class={`bg-black/80 border-l-8 ${themeBorderClass} p-8 shadow-brutal`}>
          <h2 class={`text-xs font-black uppercase ${themeColorClass} mb-6 tracking-[0.3em] flex items-center gap-3`}>
            <span class={`w-2 h-2 ${themeBgClass} rounded-full`}></span> L'INTENTION
          </h2>
          <p class="text-xl font-medium text-white/90 leading-relaxed italic border-b border-white/10 pb-6 mb-6">
            "{mission.vibe}"
          </p>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {mission.stats.map(stat => (
              <div class="border-l-2 border-white/10 pl-4">
                <div class="text-[9px] font-black uppercase text-secondary/40 mb-1">{stat.label}</div>
                <div class="text-lg font-black text-white">{stat.value}</div>
              </div>
            ))}
            <div class="md:col-span-2 border-t border-white/10 pt-4 mt-2">
               <div class="text-[9px] font-black uppercase text-main mb-1">Tarif de la Mission</div>
               <div class="text-3xl font-black text-white glow-cyan">{mission.price}</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Program & Stack -->
      <div class="lg:col-span-7 flex flex-col gap-10">
        <div class={`bg-[#0d0618] border-4 ${themeBorderClass} p-6 md:p-10 relative overflow-hidden`}>
          <!-- Decorative Background Text -->
          <div class="absolute -top-10 -right-10 text-[120px] font-black text-white/5 pointer-events-none select-none italic">
            MOD.{mission.stage}
          </div>

          <h2 class="text-xs font-black uppercase text-main mb-10 tracking-[0.3em] flex items-center gap-3">
             <span class="w-10 h-0.5 bg-main"></span> LE PROGRAMME
          </h2>

          <div class="flex flex-col gap-8 relative z-10">
            {mission.program.map(module => (
              <div class="group flex gap-8 items-start border-b border-white/5 pb-8 last:border-0 hover:bg-white/5 transition-colors p-4 -m-4">
                <div class="flex flex-col items-center">
                    <span class={`text-4xl font-black ${themeColorClass} opacity-20 group-hover:opacity-100 transition-all group-hover:scale-110 italic`}>{module.id}</span>
                    <div class={`w-0.5 h-full ${themeBgClass} opacity-10 group-hover:opacity-100 transition-all mt-2`}></div>
                </div>
                <div>
                  <h3 class="text-2xl font-black uppercase text-white mb-3 tracking-tighter group-hover:text-main transition-colors">{module.title}</h3>
                  <p class="text-lg font-bold text-secondary/60 leading-snug">{module.desc}</p>
                </div>
              </div>
            ))}
          </div>

          <!-- Technical Stack -->
          <div class="mt-12 pt-8 border-t-4 border-white/10">
             <h4 class="text-[10px] font-black uppercase text-main mb-4 tracking-widest">Stack Technique & Compétences</h4>
             <div class="flex flex-wrap gap-2">
                {mission.stack.map(tech => (
                  <span class={`border-2 ${themeBorderClass} text-white text-[10px] font-black px-4 py-1.5 uppercase bg-black hover:${themeBgClass} hover:text-black transition-all cursor-crosshair`}>
                    {tech}
                  </span>
                ))}
             </div>
          </div>
        </div>

        <!-- CALL TO ACTION -->
        <div class="flex flex-col md:flex-row gap-6 mt-4">
           <div class="flex-grow">
              <SanwaButton text="Engager la Mission" btnKey="A" type="primary" href="/contact" />
           </div>
           <div class="flex-grow">
              <SanwaButton text="Retour Dossier" btnKey="B" type="alert" href="/#mission" />
           </div>
        </div>
      </div>
    </div>

    <!-- Similar Missions Section -->
    <section class="mt-32">
       <div class="flex items-center gap-4 mb-12">
          <h2 class="text-3xl font-black uppercase italic text-white tracking-tighter">Missions Similaires</h2>
          <div class="flex-grow h-1 bg-gradient-to-r from-magenta to-transparent"></div>
          <div class="text-[10px] font-mono text-magenta animate-pulse">RECOMMANDATIONS SYSTÈME</div>
       </div>
       
       <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {similarMissions.map((m) => (
            <ExpertiseCard {...m} />
          ))}
       </div>
    </section>

    <!-- Background Metadata Footer -->
    <div class="mt-24 pt-8 border-t-2 border-white/10 grid grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="flex flex-col">
            <span class="text-[8px] font-black text-secondary/30 uppercase tracking-widest mb-1">Encrypted Source</span>
            <span class="text-[10px] font-mono text-white/60">RAYONIS-ACADEMY-OS://MISSION_BRIEF_{mission.stage}.LOG</span>
        </div>
        <div class="flex flex-col">
            <span class="text-[8px] font-black text-secondary/30 uppercase tracking-widest mb-1">Authorization Level</span>
            <span class="text-[10px] font-mono text-white/60">CLEARANCE: LEVEL_4 (ADMIN)</span>
        </div>
        <div class="hidden lg:flex flex-col">
            <span class="text-[8px] font-black text-secondary/30 uppercase tracking-widest mb-1">Transmission Date</span>
            <span class="text-[10px] font-mono text-white/60">SYSDATE: 21.04.2026</span>
        </div>
        <div class="hidden lg:flex flex-col text-right">
            <span class="text-[8px] font-black text-secondary/30 uppercase tracking-widest mb-1">Academy Protocol</span>
            <span class="text-[10px] font-mono text-white/60">DE LA CONSCIENCE À LA MAÎTRISE</span>
        </div>
    </div>
  </main>
</Layout>

<style>
  main {
    background-image: 
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    background-attachment: fixed;
  }

  @keyframes slide-in {
    from { transform: translateX(-20px); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }

  .animate-slide-in {
    animation: slide-in 0.6s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  /* Custom Glows */
  .glow-cyan { filter: drop-shadow(0 0 15px var(--color-main)); }
  .glow-magenta { filter: drop-shadow(0 0 15px var(--color-magenta)); }
  .glow-red { filter: drop-shadow(0 0 15px var(--color-alert)); }
</style>
