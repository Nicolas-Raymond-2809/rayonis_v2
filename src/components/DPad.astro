---

---

<div class="relative w-32 h-32 md:w-40 md:h-40 select-none">
  <!-- D-Pad Base Circle (optional decorative touch) -->
  <div
    class="absolute inset-0 rounded-full bg-black/20 border-4 border-black/10"
  >
  </div>

  <div class="grid grid-cols-3 grid-rows-3 w-full h-full relative z-10 p-2">
    <!-- Top -->
    <div class="col-start-2">
      <button
        id="dpad-up"
        class="w-full h-full bg-[#1a0b33] border-4 border-black flex items-center justify-center shadow-[0_6px_0_#000] active:shadow-none active:translate-y-[6px] transition-all glow-cyan/20"
        aria-label="Scroll Up"
      >
        <div
          class="w-0 h-0 border-l-[8px] border-l-transparent border-r-[8px] border-r-transparent border-b-[12px] border-b-main glow-cyan"
        >
        </div>
      </button>
    </div>

    <!-- Middle Row -->
    <div class="row-start-2 col-start-1">
      <button
        id="dpad-left"
        class="w-full h-full bg-[#1a0b33] border-4 border-black flex items-center justify-center shadow-[0_6px_0_#000] active:shadow-none active:translate-y-[6px] transition-all glow-cyan/20"
        aria-label="Scroll Left"
      >
        <div
          class="w-0 h-0 border-t-[8px] border-t-transparent border-b-[8px] border-b-transparent border-r-[12px] border-r-main glow-cyan"
        >
        </div>
      </button>
    </div>

    <div
      class="row-start-2 col-start-2 bg-[#1a0b33] border-x-4 border-black border-y-0 relative z-20"
    >
      <!-- Center connector -->
      <div
        class="absolute inset-0 bg-black/10 flex items-center justify-center"
      >
        <div class="w-4 h-4 rounded-full border-2 border-main/20 glow-cyan/10"></div>
      </div>
    </div>

    <div class="row-start-2 col-start-3">
      <button
        id="dpad-right"
        class="w-full h-full bg-[#1a0b33] border-4 border-black flex items-center justify-center shadow-[0_6px_0_#000] active:shadow-none active:translate-y-[6px] transition-all glow-cyan/20"
        aria-label="Scroll Right"
      >
        <div
          class="w-0 h-0 border-t-[8px] border-t-transparent border-b-[8px] border-b-transparent border-l-[12px] border-l-main glow-cyan"
        >
        </div>
      </button>
    </div>

    <!-- Bottom -->
    <div class="row-start-3 col-start-2">
      <button
        id="dpad-down"
        class="w-full h-full bg-[#1a0b33] border-4 border-black flex items-center justify-center shadow-[0_6px_0_#000] active:shadow-none active:translate-y-[6px] transition-all glow-cyan/20"
        aria-label="Scroll Down"
      >
        <div
          class="w-0 h-0 border-l-[8px] border-l-transparent border-r-[8px] border-r-transparent border-t-[12px] border-t-main glow-cyan"
        >
        </div>
      </button>
    </div>
  </div>
</div>

<script>
  const monitor = document.getElementById("arcade-monitor-content");
  const scrollAmount = 150;

  function setupDpad(id: string, dx: number, dy: number) {
    const btn = document.getElementById(id);
    const menu = document.getElementById('arcade-menu');
    if (!btn || !monitor) return;

    let scrollInterval: number | undefined;
    
    const action = () => {
      const isMenuOpen = menu && !menu.classList.contains('hidden');
      if (isMenuOpen) {
        // All D-Pad buttons navigate focus in the menu
        (window as any).navigateArcadeFocus?.(dy > 0 || dx > 0 ? 1 : -1);
      } else {
        if (dy !== 0) {
          // Vertical axis: Scroll
          monitor.scrollBy({ top: dy, left: 0, behavior: 'smooth' });
        } else if (dx !== 0) {
          // Horizontal axis: Focus Navigation
          (window as any).navigateArcadeFocus?.(dx > 0 ? 1 : -1);
        }
      }
    };

    btn.addEventListener('mousedown', () => {
      action();
      // Continuous scroll only for background vertical scroll
      const isMenuOpen = menu && !menu.classList.contains('hidden');
      if (!isMenuOpen && dy !== 0) {
        scrollInterval = window.setInterval(action, 200);
      }
    });

    btn.addEventListener('mouseup', () => clearInterval(scrollInterval));
    btn.addEventListener('mouseleave', () => clearInterval(scrollInterval));
    
    // Touch support
    btn.addEventListener('touchstart', (e) => {
      e.preventDefault();
      action();
      const isMenuOpen = menu && !menu.classList.contains('hidden');
      if (!isMenuOpen && dy !== 0) {
        scrollInterval = window.setInterval(action, 200);
      }
    }, { passive: false });
    
    btn.addEventListener('touchend', () => clearInterval(scrollInterval));
  }

  setupDpad('dpad-up', 0, -scrollAmount);
  setupDpad('dpad-down', 0, scrollAmount);
  setupDpad('dpad-left', -1, 0); // dx is now a direction flag for focus
  setupDpad('dpad-right', 1, 0);

  // Keyboard Arrow Mapping
  const keyMap: Record<string, string> = {
    'ArrowUp': 'dpad-up',
    'ArrowDown': 'dpad-down',
    'ArrowLeft': 'dpad-left',
    'ArrowRight': 'dpad-right'
  };

  window.addEventListener('keydown', (e) => {
    const btnId = keyMap[e.key];
    if (btnId) {
      const btn = document.getElementById(btnId);
      const menu = document.getElementById('arcade-menu');
      const isMenuOpen = menu && !menu.classList.contains('hidden');

      if (btn) {
        btn.classList.add('is-pressed-dpad');
        
        if (isMenuOpen) {
          if (e.key === 'ArrowDown' || e.key === 'ArrowRight') (window as any).navigateArcadeFocus?.(1);
          if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') (window as any).navigateArcadeFocus?.(-1);
        } else {
          // Logic Split: Vertical to Scroll, Horizontal to Focus
          if (e.key === 'ArrowUp' || e.key === 'ArrowDown') {
            monitor?.scrollBy({ 
              top: e.key === 'ArrowUp' ? -scrollAmount : scrollAmount,
              left: 0,
              behavior: 'smooth' 
            });
          } else {
            // Horizontal keys cycle the focus
            (window as any).navigateArcadeFocus?.(e.key === 'ArrowRight' ? 1 : -1);
          }
        }
      }
    }
  });

  window.addEventListener('keyup', (e) => {
    const btnId = keyMap[e.key];
    if (btnId) {
      const btn = document.getElementById(btnId);
      btn?.classList.remove('is-pressed-dpad');
    }
  });
</script>

<style>
  /* Ensure perfect rectangles as requested */
  button {
    border-radius: 0 !important;
  }
</style>
